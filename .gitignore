# Universal/runtime state — machine-specific, regenerated per host
fish/.config/fish/fish_variables

# Plugin artifacts (reproducible via `fisher update` from fish_plugins):
# ignore these dirs wholesale, then whitelist hand-written files below.
fish/.config/fish/conf.d/*
fish/.config/fish/completions/*
fish/.config/fish/functions/*

# --- Hand-written config to keep tracked ---
!fish/.config/fish/conf.d/aliases.fish
!fish/.config/fish/conf.d/paths.fish
!fish/.config/fish/conf.d/env.fish
!fish/.config/fish/conf.d/zoxide.fish
!fish/.config/fish/conf.d/conda.fish
!fish/.config/fish/conf.d/rustup.fish
!fish/.config/fish/conf.d/rose-pine-moon.fish
!fish/.config/fish/functions/fish_prompt.fish
!fish/.config/fish/functions/y.fish
!fish/.config/fish/functions/toggle_bindings.fish
