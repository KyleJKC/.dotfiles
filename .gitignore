# Universal/runtime state — machine-specific, regenerated per host
fish/.config/fish/fish_variables

# Generated completions (bun, fisher, fzf) — regenerable, not hand-written
fish/.config/fish/completions/*

# Fisher-installed plugin functions. Internal helpers are `_`-prefixed; the two
# named files are the only non-prefixed entry points (jorgebucaran/fisher,
# patrickf1/fzf.fish). Everything else in functions/ is hand-written & tracked.
fish/.config/fish/functions/_*.fish
fish/.config/fish/functions/fisher.fish
fish/.config/fish/functions/fzf_configure_bindings.fish

# Plugin-dropped conf.d snippets (autopair.fish, fzf.fish).
# Everything else in conf.d/ is hand-written & tracked.
fish/.config/fish/conf.d/autopair.fish
fish/.config/fish/conf.d/fzf.fish
